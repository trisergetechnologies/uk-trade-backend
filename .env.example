PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/uk_trade
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
APP_TZ=Asia/Kolkata

# Seed scripts (npm run seed, seed:reset-users, seed:packages, etc.) run only when this is exactly false.
# Leave unset or true in production to block accidental seeds.
PROD_PROTECT=false

# Tree migration (npm run migrate:tree-main-root) requires BOTH of the following:
# MIGRATE_TREE_CONFIRM=YES_I_HAVE_A_DATABASE_BACKUP

# `npm run seed` creates admin + main user. Emails must differ (unique index).
ADMIN_BOOTSTRAP_EMAIL=admin@uktrade.local
SEED_USER_EMAIL=user@uktrade.local
SEED_USER_NAME=Main User
# Same plaintext password for both seeded accounts (falls back to ADMIN_BOOTSTRAP_PASSWORD, then UkTrade@Dev123).
SEED_SHARED_PASSWORD=UkTrade@Dev123
ADMIN_BOOTSTRAP_PASSWORD=UkTrade@Dev123

CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET
CLOUDINARY_FOLDER

# Matching income config
MATCHING_INCOME_ENABLED=true
MATCHING_INCOME_PERCENT=4

# 64 hex characters (32 bytes). Required for storing recoverable passwordCipher on users.
# Generate e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSWORD_CIPHER_KEY=