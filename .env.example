PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/uk_trade
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
APP_TZ=Asia/Kolkata

# `npm run seed` creates admin + main user. Emails must differ (unique index).
ADMIN_BOOTSTRAP_EMAIL=admin@uktrade.local
SEED_USER_EMAIL=user@uktrade.local
SEED_USER_NAME=Main User
# Same plaintext password for both seeded accounts (falls back to ADMIN_BOOTSTRAP_PASSWORD, then UkTrade@Dev123).
SEED_SHARED_PASSWORD=UkTrade@Dev123
ADMIN_BOOTSTRAP_PASSWORD=UkTrade@Dev123

CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET
CLOUDINARY_FOLDER